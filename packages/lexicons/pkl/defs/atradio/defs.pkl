amends "../../schema/lexicon.pkl"

lexicon = 1
id = "fm.atradio.defs"
description = "Shared objects for atradio.fm lexicons."
defs = new Mapping<String, ObjectType> {
  ["stationInfo"] {
    type = "object"
    description = "A self-contained snapshot of a radio station."
    required = List("stationId", "name", "streamUrl", "source")
    properties {
      ["stationId"] = new StringType {
        type = "string"
        description = "Source-prefixed stable id, e.g. rb:uuid, tunein:s123, custom:xyz."
        maxLength = 512
      }
      ["name"] = new StringType {
        type = "string"
        minLength = 1
        maxLength = 512
      }
      ["streamUrl"] = new StringType {
        type = "string"
        description = "Direct, playable stream URL."
        format = "uri"
      }
      ["source"] = new StringType {
        type = "string"
        description = "Provider: radio-browser | tunein | custom."
      }
      ["description"] = new StringType {
        type = "string"
        maxLength = 2000
      }
      ["genre"] = new StringType {
        type = "string"
        maxLength = 256
      }
      ["homepage"] = new StringType {
        type = "string"
        format = "uri"
      }
      ["logo"] = new StringType {
        type = "string"
        description = "Logo/artwork URL."
        format = "uri"
      }
      ["country"] = new StringType {
        type = "string"
      }
      ["language"] = new StringType {
        type = "string"
      }
      ["bitrate"] = new IntegerType {
        type = "integer"
        minimum = 0
      }
      ["codec"] = new StringType {
        type = "string"
      }
      ["tags"] = new Array {
        type = "array"
        items = new StringType {
          type = "string"
        }
      }
    }
  }
  ["stationView"] {
    type = "object"
    description = "A station snapshot paired with its record uri (query output item)."
    required = List("uri", "station", "createdAt")
    properties {
      ["uri"] = new StringType {
        type = "string"
        format = "at-uri"
      }
      ["station"] = new Ref {
        type = "ref"
        ref = "fm.atradio.defs#stationInfo"
      }
      ["createdAt"] = new StringType {
        type = "string"
        format = "datetime"
      }
    }
  }
  ["actorInfo"] {
    type = "object"
    description = "A minimal public snapshot of an actor."
    required = List("did")
    properties {
      ["did"] = new StringType {
        type = "string"
        format = "did"
      }
      ["handle"] = new StringType {
        type = "string"
        format = "at-identifier"
      }
      ["displayName"] = new StringType {
        type = "string"
      }
      ["avatar"] = new StringType {
        type = "string"
        description = "Avatar URL."
        format = "uri"
      }
    }
  }
  ["playView"] {
    type = "object"
    description = "A single play event: a station an actor listened to at a point in time."
    required = List("station", "playedAt")
    properties {
      ["station"] = new Ref {
        type = "ref"
        ref = "fm.atradio.defs#stationInfo"
      }
      ["playedAt"] = new StringType {
        type = "string"
        format = "datetime"
      }
      ["actor"] = new Ref {
        type = "ref"
        ref = "fm.atradio.defs#actorInfo"
      }
    }
  }
  ["listenerCount"] {
    type = "object"
    description = "Unique-listener count for a single station."
    required = List("stationId", "listeners")
    properties {
      ["stationId"] = new StringType {
        type = "string"
      }
      ["listeners"] = new IntegerType {
        type = "integer"
        description = "Number of distinct actors who have played this station."
        minimum = 0
      }
    }
  }
  ["commentView"] {
    type = "object"
    description = "A comment on a station, paired with its record uri and author."
    required = List("uri", "station", "text", "createdAt")
    properties {
      ["uri"] = new StringType {
        type = "string"
        format = "at-uri"
      }
      ["author"] = new Ref {
        type = "ref"
        ref = "fm.atradio.defs#actorInfo"
      }
      ["station"] = new Ref {
        type = "ref"
        ref = "fm.atradio.defs#stationInfo"
      }
      ["text"] = new StringType {
        type = "string"
      }
      ["facets"] = new Array {
        type = "array"
        items = new Ref {
          type = "ref"
          ref = "fm.atradio.comment#mention"
        }
      }
      ["gif"] = new Ref {
        type = "ref"
        ref = "fm.atradio.comment#gif"
      }
      ["createdAt"] = new StringType {
        type = "string"
        format = "datetime"
      }
    }
  }
  ["notificationView"] {
    type = "object"
    description = "A single notification for an actor."
    required = List("uri", "reason", "author", "createdAt", "isRead")
    properties {
      ["uri"] = new StringType {
        type = "string"
        description = "URI of the subject record (the comment)."
        format = "at-uri"
      }
      ["reason"] = new StringType {
        type = "string"
        description = "Why this notification exists: mention | comment."
      }
      ["author"] = new Ref {
        type = "ref"
        ref = "fm.atradio.defs#actorInfo"
      }
      ["station"] = new Ref {
        type = "ref"
        ref = "fm.atradio.defs#stationInfo"
      }
      ["text"] = new StringType {
        type = "string"
        description = "Snapshot of the comment text."
      }
      ["createdAt"] = new StringType {
        type = "string"
        format = "datetime"
      }
      ["isRead"] = new BooleanType {
        type = "boolean"
      }
    }
  }
}
