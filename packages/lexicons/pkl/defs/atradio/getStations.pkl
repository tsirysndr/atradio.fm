amends "../../schema/lexicon.pkl"

lexicon = 1
id = "fm.atradio.getStations"
defs = new Mapping<String, Query> {
  ["main"] {
    type = "query"
    description = "List a user's own radio stations."
    parameters = new Params {
      required = List("actor")
      properties {
        ["actor"] = new StringType {
          type = "string"
          description = "DID or handle of the user."
          format = "at-identifier"
        }
        ["limit"] = new IntegerType {
          type = "integer"
          minimum = 1
          maximum = 100
        }
        ["cursor"] = new StringType {
          type = "string"
        }
        ["q"] = new StringType {
          type = "string"
          description = "Filter by text (name or genre)."
        }
        ["source"] = new StringType {
          type = "string"
          description = "Filter by provider: radio-browser | tunein | custom."
        }
        ["sort"] = new StringType {
          type = "string"
          description = "Sort order: recent | name | -name."
        }
      }
    }
    output {
      encoding = "application/json"
      schema = new ObjectType {
        type = "object"
        required = List("total", "items")
        properties {
          ["cursor"] = new StringType {
            type = "string"
          }
          ["total"] = new IntegerType {
            type = "integer"
            description = "Total number of records for the actor."
          }
          ["items"] = new Array {
            type = "array"
            items = new Ref {
              type = "ref"
              ref = "fm.atradio.defs#stationView"
            }
          }
        }
      }
    }
  }
}
