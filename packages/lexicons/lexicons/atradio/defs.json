{
  "lexicon": 1,
  "id": "fm.atradio.defs",
  "description": "Shared objects for atradio.fm lexicons.",
  "defs": {
    "stationInfo": {
      "type": "object",
      "description": "A self-contained snapshot of a radio station.",
      "required": [
        "stationId",
        "name",
        "streamUrl",
        "source"
      ],
      "properties": {
        "stationId": {
          "type": "string",
          "description": "Source-prefixed stable id, e.g. rb:uuid, tunein:s123, custom:xyz.",
          "maxLength": 512
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "streamUrl": {
          "type": "string",
          "description": "Direct, playable stream URL.",
          "format": "uri"
        },
        "source": {
          "type": "string",
          "description": "Provider: radio-browser | tunein | custom."
        },
        "description": {
          "type": "string",
          "maxLength": 2000
        },
        "genre": {
          "type": "string",
          "maxLength": 256
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "logo": {
          "type": "string",
          "description": "Logo/artwork URL.",
          "format": "uri"
        },
        "country": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "bitrate": {
          "type": "integer",
          "minimum": 0
        },
        "codec": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "stationView": {
      "type": "object",
      "description": "A station snapshot paired with its record uri (query output item).",
      "required": [
        "uri",
        "station",
        "createdAt"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "at-uri"
        },
        "station": {
          "type": "ref",
          "ref": "fm.atradio.defs#stationInfo"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime"
        }
      }
    }
  }
}
