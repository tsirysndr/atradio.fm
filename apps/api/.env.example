# Postgres. Xata (hosted) needs TLS: append ?sslmode=require.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# Local docker (see root compose.yml) — no TLS:
# DATABASE_URL=postgresql://atradio:atradio@localhost:5432/atradio

# HTTP port for the Express server.
PORT=8080

# XRPC read API rate limit, per IP (fixed window). Defaults shown.
# XRPC_RATE_LIMIT=120
# XRPC_RATE_WINDOW_MS=60000

# Optional Redis cache (speeds up XRPC reads). Unset = caching disabled.
# Local docker (see root compose.yml):
REDIS_URL=redis://localhost:6379

# Optional: comma-separated Jetstream hosts (defaults to all four official ones).
# JETSTREAM_HOSTS=jetstream1.us-east.bsky.network,jetstream2.us-east.bsky.network,jetstream1.us-west.bsky.network,jetstream2.us-west.bsky.network

# Optional: Discord incoming-webhook URL for the #firehose channel. When set,
# every Jetstream event is forwarded (batched) to that channel. Create it in
# Discord: #firehose → Edit Channel → Integrations → Webhooks → New Webhook.
# DISCORD_FIREHOSE_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
