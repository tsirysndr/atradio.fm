# Template for apps/web/.env.production (which is gitignored — copy this file to
# .env.production and fill in the secret). Baked into the build by
# `vite build` (mode=production).

# The media proxy (stream / tunein / image / icy). One knob for all four routes.
# VITE_TUNEIN_PROXY / VITE_ICY_PROXY still override individually if ever needed.
VITE_MEDIA_PROXY=https://media.atradio.fm
# AppView XRPC base (discovery + optional public-profile reads).
VITE_APPVIEW_URL=https://api.atradio.fm
# KLIPY media API key (GIF / sticker / clip picker). Get one at
# https://klipy.com/developers. Key below is MASKED — replace with the real one
# in your gitignored .env.production. Keep the real key OUT of git.
VITE_KLIPY_API_KEY=WDTG2KZUD1************************************************h0rP
