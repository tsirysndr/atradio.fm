# atradio.fm web env reference (all optional; Vite bakes VITE_* in at build).
#
# Loading order (Vite): .env  <  .env.local  <  .env.<mode>  <  .env.<mode>.local
#   - dev:  copy this to `.env.local` and set the local API URL.
#   - prod: values live in `.env.production` (committed).

# AppView XRPC base (public profiles + discovery).
#   dev : http://127.0.0.1:8080   prod: https://api.atradio.fm
VITE_APPVIEW_URL=http://127.0.0.1:8080

# Media proxies. In dev these default to Vite's built-in proxy (leave unset);
# in prod they point at the deployed API.
#   VITE_TUNEIN_PROXY=https://api.atradio.fm/api/tunein
#   VITE_ICY_PROXY=https://api.atradio.fm/api/icy

# KLIPY media API key — enables the GIF / sticker / clip picker in comments.
# Get one at https://klipy.com/developers. Do NOT commit the real key; set it
# via your local .env.local and your production deploy environment.
#   VITE_KLIPY_API_KEY=your_klipy_key
