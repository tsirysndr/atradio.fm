# Baked into the build by `vite build` (mode=production).
# Point the TuneIn + ICY media proxies at the deployed API (CORS is open there).
VITE_TUNEIN_PROXY=https://api.atradio.fm/api/tunein
VITE_ICY_PROXY=https://api.atradio.fm/api/icy
# AppView XRPC base (discovery + optional public-profile reads).
VITE_APPVIEW_URL=https://api.atradio.fm
