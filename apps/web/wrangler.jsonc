{
  // Cloudflare Workers static-assets deploy for the SPA (no Worker script).
  // `wrangler deploy` uploads ./dist; the SPA fallback serves index.html for
  // client routes like /oauth/callback and /profile/:actor.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "atradio-web",
  "compatibility_date": "2025-01-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
