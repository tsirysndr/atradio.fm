{
  "name": "@atradio/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for atradio.fm, built on atcute",
  "type": "module",
  "license": "MIT",
  "repository": "github:tsirysndr/atradio.fm",
  "homepage": "https://atradio.fm",
  "keywords": [
    "atradio",
    "atproto",
    "at-protocol",
    "bluesky",
    "atcute",
    "radio",
    "internet-radio",
    "sdk"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@atcute/atproto": "^3.1.10",
    "@atcute/client": "^4.2.1",
    "@atcute/lexicons": "^1.3.1",
    "@atcute/tid": "^1.1.2",
    "@atradio/lexicons": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "//": "Dev resolves `.` to src (bun/vite/tsx). publish-typescript.sh rewrites exports/main/types → dist at publish time (bun's publishConfig doesn't cover exports), then restores this file."
}
